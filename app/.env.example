# Template de desenvolvimento — copie para .env e preencha se necessário.
# NUNCA commite o .env — ele está no .gitignore.
#
# Produção: pnpm env:pull  →  baixa .env.production do Bitwarden

VITE_API_URL=http://localhost:43111
VITE_API_VERSION=v1
VITE_SENTRY_DSN=
